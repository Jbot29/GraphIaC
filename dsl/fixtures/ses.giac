domain = "begrif.co"

mail : SESDomainIdentity(domain: domain)
hz   : HostedZone(domain_name: domain)
role : IAMRole
fn   : LambdaZipFile(runtime: "python3.12", handler: "mail.handler", zip_file_path: "mail.zip")

hz -> mail                      # backwards on purpose — the parser normalizes
fn -> mail : (role_g_id: role)  # three-party edge: the role rides as an arg
role -> fn
